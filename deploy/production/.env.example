# AgentAPI production environment template.
#
# Copy to your secret manager, platform environment, or an untracked .env file.
# Do not commit real secrets. Values below are examples and must be replaced.
#
# Required startup flags that are not environment-backed today:
#   -addr :8081
#   -store-backend sql
#   -workspace /workspace
#   -enable-user-system
#   -allow-dangerous-tools=false

# -----------------------------------------------------------------------------
# Container images
# -----------------------------------------------------------------------------
# GitHub Actions publishes these GHCR images on every main deploy. The server
# deploy path should pull these tags instead of building on the test host.
AGENT_API_IMAGE=ghcr.io/yige666s/claude-codex/agentapi:main
AGENT_WEB_IMAGE=ghcr.io/yige666s/claude-codex/agentweb:main

# -----------------------------------------------------------------------------
# Storage: Postgres
# -----------------------------------------------------------------------------
AGENT_API_STORE_BACKEND=sql
AGENT_API_SQL_DRIVER=pgx
AGENT_API_SQL_DIALECT=postgres
AGENT_API_SQL_DSN=postgres://agentapi:REPLACE_ME@postgres.example.com:5432/agentapi?sslmode=require
AGENT_API_SQL_MAX_OPEN_CONNS=30
AGENT_API_SQL_MAX_IDLE_CONNS=10
AGENT_API_SQL_CONN_MAX_LIFETIME=30m

# Local fallback data and per-user workspace roots.
AGENT_API_DATA_DIR=/var/lib/agentapi
AGENT_API_USER_WORKSPACE_ROOT=/var/lib/agentapi/workspaces
AGENT_API_ALLOW_CUSTOM_WORKING_DIR=false

# Published service ports. Bind internal dependencies to localhost unless they
# are intentionally protected by a private network or authenticated gateway.
AGENT_WEB_HOST=127.0.0.1
AGENT_WEB_PORT=8080
AGENT_API_HOST=127.0.0.1
AGENT_API_PORT=8081
AGENT_API_POSTGRES_HOST=127.0.0.1
AGENT_API_POSTGRES_PORT=5432
AGENT_API_REDIS_HOST=127.0.0.1
AGENT_API_REDIS_PORT=6379
AGENT_API_KAFKA_HOST=127.0.0.1
AGENT_API_KAFKA_PORT=19092
AGENT_API_MINIO_HOST=127.0.0.1
AGENT_API_MINIO_PORT=9000
AGENT_API_MINIO_CONSOLE_HOST=127.0.0.1
AGENT_API_MINIO_CONSOLE_PORT=9001
AGENT_API_QDRANT_HOST=127.0.0.1
AGENT_API_QDRANT_PORT=6333

# -----------------------------------------------------------------------------
# Auth and browser security
# -----------------------------------------------------------------------------
AGENT_API_ENABLE_USER_SYSTEM=true
AGENT_API_AUTH_MODE=jwt
AGENT_API_AUTH_TOKEN=
AGENT_API_JWT_SECRET=REPLACE_WITH_32_PLUS_BYTES_RANDOM_SECRET
AGENT_API_ADMIN_TOKEN=REPLACE_WITH_32_PLUS_BYTES_RANDOM_ADMIN_TOKEN
AGENT_API_JWT_ISSUER=https://api.example.com
AGENT_API_JWT_AUDIENCE=agentapi-web
AGENT_API_JWT_USER_CLAIM=sub
AGENT_API_AUTH_ACCESS_TTL=15m
AGENT_API_AUTH_REFRESH_TTL=720h

# Optional email verification for registration.
AGENT_API_EMAIL_VERIFICATION_REQUIRED=false
AGENT_API_EMAIL_VERIFICATION_TTL=24h
AGENT_API_EMAIL_PROVIDER=resend
AGENT_API_EMAIL_FROM=AgentAPI <noreply@example.com>
AGENT_API_EMAIL_PUBLIC_BASE_URL=https://www.example.com
AGENT_API_RESEND_API_KEY=REPLACE_WITH_RESEND_API_KEY
AGENT_API_RESEND_BASE_URL=

# If using cookie auth instead of bearer JWT, set cookie and CSRF options.
AGENT_API_SESSION_COOKIE_NAME=agentapi_session
AGENT_API_SESSION_COOKIE_SECRET=REPLACE_WITH_32_PLUS_BYTES_RANDOM_SECRET
AGENT_API_SESSION_COOKIE_DOMAIN=.example.com
AGENT_API_SESSION_COOKIE_SECURE=true
AGENT_API_SESSION_COOKIE_SAMESITE=lax
AGENT_API_CSRF_ENABLED=true
AGENT_API_CSRF_COOKIE_NAME=agentapi_csrf
AGENT_API_CSRF_HEADER_NAME=X-CSRF-Token

# Only list exact browser origins that should call the API.
# Same-origin frontend deployments may leave this empty. Split-origin
# deployments should set it to the static frontend origin, for example
# https://app.example.com.
AGENT_API_CORS_ALLOWED_ORIGINS=https://app.example.com
AGENT_API_CORS_ALLOW_CREDENTIALS=true

# Frontend build-time setting for apps/web. Leave empty when the frontend is
# served from the same origin and /v1 is reverse-proxied to AgentAPI. Set an
# absolute origin, such as https://api.example.com, for split frontend/API
# hosting. This is consumed by Vite at build time, not by cmd/agentapi.
VITE_AGENT_API_BASE_URL=

# Trusted gateway mode, only when auth is terminated upstream.
AGENT_API_TRUSTED_USER_HEADER=X-User-ID
AGENT_API_TRUSTED_SECRET_HEADER=X-Agent-Gateway-Secret
AGENT_API_TRUSTED_SECRET=

# -----------------------------------------------------------------------------
# Object storage: artifacts and attachments
# -----------------------------------------------------------------------------
AGENT_API_ARTIFACT_STORE=s3
# Cloudflare R2 S3-compatible endpoint. Create R2 access keys from the
# Cloudflare dashboard; CLOUDFLARE_API_TOKEN is only for bucket administration
# through wrangler and is not accepted by the S3-compatible object client.
CLOUDFLARE_ACCOUNT_ID=5c11ff96d03d238d51aef31150a87101
# Optional for wrangler/admin scripts only; AgentAPI does not read this value.
CLOUDFLARE_API_TOKEN=REPLACE_WITH_CLOUDFLARE_API_TOKEN
AGENT_API_ARTIFACT_S3_ENDPOINT=5c11ff96d03d238d51aef31150a87101.r2.cloudflarestorage.com
AGENT_API_ARTIFACT_S3_ACCESS_KEY=REPLACE_WITH_R2_ACCESS_KEY_ID
AGENT_API_ARTIFACT_S3_SECRET_KEY=REPLACE_WITH_R2_SECRET_ACCESS_KEY
AGENT_API_ARTIFACT_S3_BUCKET=agentapi
AGENT_API_ARTIFACT_S3_PREFIX=prod
AGENT_API_ARTIFACT_S3_SSL=true
AGENT_API_ASSET_MAX_BYTES=67108864
AGENT_API_LOCAL_ARTIFACT_STAGING_RETENTION=24h

# Message cold archive. Uses the artifact object store above, so with
# AGENT_API_ARTIFACT_STORE=s3 this writes old message payloads to R2.
AGENT_API_MESSAGE_ARCHIVE_WORKER_ENABLED=true
AGENT_API_MESSAGE_ARCHIVE_AFTER=720h
AGENT_API_MESSAGE_ARCHIVE_WORKER_BATCH_SIZE=100
AGENT_API_MESSAGE_ARCHIVE_WORKER_POLL_INTERVAL=1h
AGENT_API_MESSAGE_ARCHIVE_WORKER_PROCESS_TIMEOUT=2m
AGENT_API_MESSAGE_ARCHIVE_PREFIX=message-archive
AGENT_API_MESSAGE_ARCHIVE_CLEAR_PG_PAYLOAD=true

# Message attachment processing. The worker extracts text for lightweight
# formats, generates image thumbnails, and indexes extracted attachment content.
AGENT_API_MESSAGE_ATTACHMENT_WORKER_ENABLED=true
AGENT_API_MESSAGE_ATTACHMENT_WORKER_BATCH_SIZE=25
AGENT_API_MESSAGE_ATTACHMENT_WORKER_POLL_INTERVAL=5s
AGENT_API_MESSAGE_ATTACHMENT_WORKER_PROCESS_TIMEOUT=30s
AGENT_API_MESSAGE_ATTACHMENT_THUMBNAIL_MAX_DIMENSION=512

# -----------------------------------------------------------------------------
# Message search: Elasticsearch/OpenSearch full text and Qdrant semantic search
# -----------------------------------------------------------------------------
AGENT_API_MESSAGE_SEARCH_BACKEND=hybrid
AGENT_API_MESSAGE_SEARCH_ENDPOINT=https://elasticsearch.example.com:9200
AGENT_API_MESSAGE_SEARCH_INDEX=agent_messages
AGENT_API_MESSAGE_SEARCH_API_KEY=REPLACE_WITH_ES_API_KEY
AGENT_API_MESSAGE_SEARCH_USERNAME=
AGENT_API_MESSAGE_SEARCH_PASSWORD=
AGENT_API_MESSAGE_SEARCH_TIMEOUT=5s

# Elasticsearch-only index lifecycle management. Enable only after the cluster
# has the IK analyzer plugin installed for ik_max_word / ik_smart.
AGENT_API_ELASTICSEARCH_VERSION=8.15.3
AGENT_API_ELASTICSEARCH_IK_PLUGIN_URL=https://get.infini.cloud/elasticsearch/analysis-ik/8.15.3
AGENT_API_ELASTICSEARCH_HOST=127.0.0.1
AGENT_API_ELASTICSEARCH_PORT=9200
AGENT_API_MESSAGE_SEARCH_INDEX_MANAGEMENT_ENABLED=true
AGENT_API_MESSAGE_SEARCH_INDEX_LIFECYCLE_POLICY=
AGENT_API_MESSAGE_SEARCH_INDEX_TEMPLATE=
AGENT_API_MESSAGE_SEARCH_INDEX_WRITE_ALIAS=
AGENT_API_MESSAGE_SEARCH_INDEX_ANALYZER=ik_max_word
AGENT_API_MESSAGE_SEARCH_INDEX_SEARCH_ANALYZER=ik_smart
AGENT_API_MESSAGE_SEARCH_INDEX_DOWNGRADE_AFTER=2160h
AGENT_API_MESSAGE_SEARCH_INDEX_CLOSE_AFTER=4320h
AGENT_API_MESSAGE_SEARCH_INDEX_MAINTENANCE_INTERVAL=24h
AGENT_API_MESSAGE_SEARCH_INDEX_MAINTENANCE_BATCH_LIMIT=50

AGENT_API_MESSAGE_SEARCH_QDRANT_ENDPOINT=https://qdrant.example.com
AGENT_API_MESSAGE_SEARCH_QDRANT_COLLECTION=agent_messages
AGENT_API_MESSAGE_SEARCH_QDRANT_API_KEY=REPLACE_WITH_QDRANT_API_KEY
AGENT_API_MESSAGE_SEARCH_QDRANT_SCORE_THRESHOLD=0
AGENT_API_MESSAGE_SEARCH_EMBEDDING_PROVIDER=vertex
AGENT_API_MESSAGE_SEARCH_EMBEDDING_PROJECT_ID=example-gcp-project
AGENT_API_MESSAGE_SEARCH_EMBEDDING_LOCATION=global
AGENT_API_MESSAGE_SEARCH_EMBEDDING_MODEL=gemini-embedding-2
AGENT_API_MESSAGE_SEARCH_EMBEDDING_DIMENSIONS=768
AGENT_API_MESSAGE_SEARCH_EMBEDDING_TASK_TYPE=RETRIEVAL_QUERY
AGENT_API_MESSAGE_SEARCH_EMBEDDING_INDEX_TASK_TYPE=RETRIEVAL_DOCUMENT
AGENT_API_MESSAGE_SEARCH_EMBEDDING_AUTO_TRUNCATE=true
AGENT_API_MESSAGE_SEARCH_RRF_K=60

# Saved memory vector retrieval. Defaults mirror the message embedding provider
# but use a separate Qdrant collection for memory items.
AGENT_API_MEMORY_VECTOR_ENABLED=true
AGENT_API_MEMORY_VECTOR_QDRANT_ENDPOINT=https://qdrant.example.com
AGENT_API_MEMORY_VECTOR_QDRANT_COLLECTION=agent_memories
AGENT_API_MEMORY_VECTOR_QDRANT_API_KEY=REPLACE_WITH_QDRANT_API_KEY
AGENT_API_MEMORY_VECTOR_QDRANT_SCORE_THRESHOLD=0
AGENT_API_MEMORY_VECTOR_EMBEDDING_PROVIDER=vertex
AGENT_API_MEMORY_VECTOR_EMBEDDING_PROJECT_ID=example-gcp-project
AGENT_API_MEMORY_VECTOR_EMBEDDING_LOCATION=global
AGENT_API_MEMORY_VECTOR_EMBEDDING_MODEL=gemini-embedding-2
AGENT_API_MEMORY_VECTOR_EMBEDDING_DIMENSIONS=768
AGENT_API_MEMORY_VECTOR_EMBEDDING_TASK_TYPE=RETRIEVAL_QUERY
AGENT_API_MEMORY_VECTOR_EMBEDDING_INDEX_TASK_TYPE=RETRIEVAL_DOCUMENT
AGENT_API_MEMORY_VECTOR_EMBEDDING_AUTO_TRUNCATE=true
AGENT_API_MEMORY_VECTOR_RRF_K=60

# Message events. Use local for in-process indexing, kafka for an async worker
# chain, or dual during migration/verification.
AGENT_API_MESSAGE_EVENTS_BACKEND=kafka
AGENT_API_MESSAGE_EVENTS_KAFKA_BROKERS=redpanda:9092
AGENT_API_MESSAGE_EVENTS_KAFKA_TOPIC=agent.messages
AGENT_API_MESSAGE_EVENTS_KAFKA_CLIENT_ID=agentapi
AGENT_API_MESSAGE_EVENTS_KAFKA_CONSUMER_ENABLED=true
AGENT_API_MESSAGE_EVENTS_KAFKA_CONSUMER_GROUP=agentapi-message-workers
AGENT_API_MESSAGE_EVENTS_KAFKA_DLQ_TOPIC=agent.messages.dlq
AGENT_API_MESSAGE_EVENTS_KAFKA_RETRY_ATTEMPTS=3
AGENT_API_MESSAGE_EVENTS_KAFKA_RETRY_BACKOFF=1s
AGENT_API_MESSAGE_EVENTS_KAFKA_PROCESS_TIMEOUT=30s
AGENT_API_MESSAGE_EVENTS_PROCESSED_LOCK_BACKEND=redis
AGENT_API_MESSAGE_EVENTS_PROCESSED_LOCK_REDIS_URL=redis://:REPLACE_ME@redis.example.com:6379/1?prefix=agentapi:message:processed
AGENT_API_MESSAGE_EVENTS_PROCESSED_LOCK_TTL=24h

# Optional legacy/object session-memory store adapter. Keep unset when using SQL.
AGENT_API_OBJECT_BASE_URL=
AGENT_API_OBJECT_TOKEN=
AGENT_API_OBJECT_TIMEOUT=10s

# -----------------------------------------------------------------------------
# Rate limiting
# -----------------------------------------------------------------------------
AGENT_API_RATE_LIMIT_BACKEND=redis
AGENT_API_REDIS_URL=redis://:REPLACE_ME@redis.example.com:6379/0?prefix=agentapi
AGENT_API_REDIS_FAIL_OPEN=false
AGENT_API_OPERATION_RATE_LIMITS=auth_login=20/m,auth_register=10/h,chat_message=60/m,job_create=20/m,attachment_upload=30/m,asset_download=120/m,memory_extract=30/h,data_export=5/h,account_delete=3/h,admin_action=120/m
AGENT_API_MESSAGE_CONTEXT_CACHE_BACKEND=redis
AGENT_API_MESSAGE_CONTEXT_CACHE_REDIS_URL=redis://:REPLACE_ME@redis.example.com:6379/1?prefix=agentapi:message:ctx
AGENT_API_MESSAGE_CONTEXT_CACHE_TTL=24h
AGENT_API_SESSION_LIST_CACHE_BACKEND=redis
AGENT_API_SESSION_LIST_CACHE_REDIS_URL=redis://:REPLACE_ME@redis.example.com:6379/1?prefix=agentapi:session:list
AGENT_API_SESSION_LIST_CACHE_TTL=10m
AGENT_API_MESSAGE_SEQUENCE_BACKEND=redis
AGENT_API_MESSAGE_SEQUENCE_REDIS_URL=redis://:REPLACE_ME@redis.example.com:6379/1?prefix=agentapi:message:seq
AGENT_API_JOB_QUEUE_REDIS_URL=redis://:REPLACE_ME@redis.example.com:6379/2
AGENT_API_JOB_QUEUE_STREAM=agentapi:jobs
AGENT_API_JOB_QUEUE_CONSUMER_GROUP=agentapi-job-workers
AGENT_API_JOB_QUEUE_CONSUMER=
AGENT_API_JOB_QUEUE_BLOCK_TIMEOUT=2s
AGENT_API_JOB_QUEUE_CLAIM_IDLE=1m
AGENT_API_JOB_QUEUE_LOCK_TTL=2m
AGENT_API_JOB_WORKER_ENABLED=true
AGENT_API_JOB_EVENT_FANOUT_ENABLED=true
AGENT_API_JOB_EVENT_FANOUT_CHANNEL=agentapi:job-events
AGENT_API_JOB_EVENT_FANOUT_ORIGIN=

# The per-minute request limit is currently a flag, not an environment variable:
#   -rate-limit 60

# -----------------------------------------------------------------------------
# LLM provider and governance
# -----------------------------------------------------------------------------
# Supported providers: anthropic, openai, qwen, gemini, vertex, shortapi, custom.
AGENT_API_LLM_PROVIDER=vertex
AGENT_API_LLM_API_KEY=
AGENT_API_LLM_TOKEN=
AGENT_API_LLM_BASE_URL=
AGENT_API_LLM_FALLBACKS=
# Runtime model selection is managed from the Admin UI and persisted in SQL.
AGENT_API_LLM_MAX_ATTEMPTS=2
AGENT_API_LLM_RETRY_BACKOFF=300ms
AGENT_API_LLM_CHAT_TIMEOUT=60s
AGENT_API_LLM_SKILL_TIMEOUT=90s
AGENT_API_LLM_DAILY_TOKEN_QUOTA=500000
AGENT_API_LLM_DAILY_REQUEST_QUOTA=1000
AGENT_API_LLM_DAILY_COST_QUOTA_USD=0
AGENT_API_LLM_INPUT_COST_PER_MILLION=0.30
AGENT_API_LLM_OUTPUT_COST_PER_MILLION=2.50
AGENT_API_LLM_FAILURE_THRESHOLD=3
AGENT_API_LLM_CIRCUIT_COOLDOWN=1m

# Gemini Live mode. This exposes /v1/sessions/{session_id}/live/ws and bridges
# browser audio to Vertex Live. Transcriptions are persisted as normal messages
# and then flow through memory/search/indexing.
AGENT_API_LIVE_ENABLED=false
AGENT_API_LIVE_PROVIDER=vertex
AGENT_API_LIVE_MODEL=gemini-live-2.5-flash-preview-native-audio-09-2025
AGENT_API_LIVE_VERTEX_PROJECT_ID=
AGENT_API_LIVE_VERTEX_LOCATION=us-central1
AGENT_API_LIVE_VERTEX_BASE_URL=
AGENT_API_LIVE_VERTEX_API_VERSION=v1beta1
AGENT_API_LIVE_INPUT_AUDIO_MIME_TYPE=audio/pcm;rate=16000
AGENT_API_LIVE_OUTPUT_AUDIO_MIME_TYPE=
# Optional prebuilt Live voice name. Supported values:
# Achernar, Achird, Algenib, Algieba, Alnilam, Aoede, Autonoe, Callirrhoe,
# Charon, Despina, Enceladus, Erinome, Fenrir, Gacrux, Iapetus, Kore,
# Laomedeia, Leda, Orus, Puck, Pulcherrima, Rasalgethi, Sadachbia,
# Sadaltager, Schedar, Sulafat, Umbriel, Vindemiatrix, Zephyr, Zubenelgenubi.
AGENT_API_LIVE_VOICE_NAME=
# Optional BCP-47 response language code, for example zh-CN or en-US.
AGENT_API_LIVE_LANGUAGE_CODE=zh-CN
AGENT_API_LIVE_INPUT_TRANSCRIPTION_ENABLED=true
AGENT_API_LIVE_OUTPUT_TRANSCRIPTION_ENABLED=true
AGENT_API_LIVE_VAD_START_SENSITIVITY=START_SENSITIVITY_HIGH
AGENT_API_LIVE_VAD_END_SENSITIVITY=END_SENSITIVITY_HIGH
AGENT_API_LIVE_VAD_PREFIX_PADDING=150ms
AGENT_API_LIVE_VAD_SILENCE_DURATION=350ms
AGENT_API_LIVE_SESSION_TIMEOUT=10m

# Provider-specific credentials. Set only the provider(s) you enable.
ANTHROPIC_API_KEY=
CLAUDE_API_KEY=
ANTHROPIC_BASE_URL=
OPENAI_API_KEY=
OPENAI_BASE_URL=
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=
QWEN_API_KEY=
QWEN_BASE_URL=
GEMINI_API_KEY=
GOOGLE_API_KEY=
GEMINI_BASE_URL=
SHORTAPI_KEY=
SHORTAPI_BASE_URL=
# Preferred for production Vertex auth. Use a service account JSON with
# Vertex AI permissions; the app exchanges it for short-lived OAuth tokens and
# refreshes automatically. GOOGLE_APPLICATION_CREDENTIALS_JSON is convenient for
# platforms that store secrets as env vars. GOOGLE_APPLICATION_CREDENTIALS /
# VERTEX_SERVICE_ACCOUNT_FILE should point to a readable JSON file inside the
# AgentAPI container.
AGENT_API_SECRETS_DIR=/opt/agentapi/secrets
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_APPLICATION_CREDENTIALS_JSON=
VERTEX_SERVICE_ACCOUNT_FILE=
VERTEX_SERVICE_ACCOUNT_JSON=
VERTEX_PROJECT_ID=example-gcp-project
GOOGLE_CLOUD_PROJECT=example-gcp-project
GCP_PROJECT=example-gcp-project
VERTEX_LOCATION=us-central1
# Claude partner models use Anthropic publisher endpoints. Leave VERTEX_LOCATION
# on the regional default for Gemini/Imagen, and set this to a Claude-supported
# location such as global, us-east5, europe-west1, or asia-southeast1.
VERTEX_ANTHROPIC_LOCATION=global
GOOGLE_CLOUD_LOCATION=us-central1
VERTEX_BASE_URL=
VERTEX_IMAGE_MODEL=imagen-4.0-generate-001
VERTEX_IMAGE_ASPECT_RATIO=1:1

# The primary model is currently a flag:
#   -model gemini-2.5-pro
#   -model claude-sonnet-4-5@20250929

# -----------------------------------------------------------------------------
# Skill and tool policy
# -----------------------------------------------------------------------------
# Comma-separated directories containing skill-name/SKILL.md folders.
# Include ~/.claude/skills or /workspace/.claude/skills here when desired.
AGENT_API_SKILL_DIRS=/workspace/.claude/skills
# Empty disables the app-level WebFetch/WebSearch domain allowlist and allows all
# domains. Set a comma-separated list in production when domain egress should be
# restricted.
AGENT_API_NETWORK_ALLOWLIST=
# Optional: Tavily Search backend for WebSearch. Keep the API key in deployment
# secrets; do not commit a real key.
AGENT_API_TAVILY_API_KEY=
AGENT_API_TAVILY_SEARCH_ENDPOINT=https://api.tavily.com/search
# Optional: route WebFetch through Cloudflare Browser Rendering /crawl so pages
# are rendered and returned as Markdown instead of raw HTML. The token needs
# Browser Rendering - Edit permission.
AGENT_API_WEBFETCH_CLOUDFLARE_ACCOUNT_ID=
AGENT_API_WEBFETCH_CLOUDFLARE_API_TOKEN=
AGENT_API_WEBFETCH_CLOUDFLARE_BASE_URL=https://api.cloudflare.com/client/v4
AGENT_API_WEBFETCH_CLOUDFLARE_POLL_ATTEMPTS=8
AGENT_API_WEBFETCH_CLOUDFLARE_POLL_INTERVAL=1s
AGENT_API_WEBFETCH_CLOUDFLARE_CDP_TIMEOUT=20s
AGENT_API_WEBFETCH_CLOUDFLARE_CDP_POLL_INTERVAL=500ms
AGENT_API_SKILL_SHELL_TIMEOUT=90s

# Use docker only when the deployment intentionally provides Docker as
# privileged sandbox infrastructure.
AGENT_API_SKILL_SHELL_RUNNER=docker
AGENT_API_SKILL_SANDBOX_IMAGE=python:3.11-slim
AGENT_API_SKILL_SANDBOX_NETWORK=none
AGENT_API_SKILL_SANDBOX_MEMORY=512m
AGENT_API_SKILL_SANDBOX_CPUS=1
AGENT_API_SKILL_SANDBOX_PIDS_LIMIT=128
AGENT_API_SKILL_SANDBOX_TMPFS_SIZE=64m
AGENT_API_SKILL_SANDBOX_PREPULL_IMAGES=python:3.12-slim,node:22-alpine
AGENT_API_SKILL_SANDBOX_WARM_POOL_SIZE=1

# Model routing keeps everyday chat/search quick while preserving Pro for
# complex work and skill/document generation. Live mode has separate settings.
AGENT_API_MODEL=gemini-2.5-pro
AGENT_API_LLM_MODEL_ROUTES=default=gemini-2.5-pro,chat=gemini-2.5-flash,chat:normal=gemini-2.5-flash,chat:search=gemini-2.5-flash,chat:complex=gemini-2.5-pro,skill=gemini-2.5-pro

# -----------------------------------------------------------------------------
# Data lifecycle and operations
# -----------------------------------------------------------------------------
AGENT_API_RETENTION_DAYS=30
AGENT_API_SHUTDOWN_TIMEOUT=30s

# Backup automation. The app does not perform backups itself; these values are
# consumed by deployment/operations jobs and are checked by check-env.mjs.
AGENT_API_BACKUP_ENABLED=false
AGENT_API_BACKUP_POSTGRES_DSN=postgres://agentapi_backup:REPLACE_ME@postgres.example.com:5432/agentapi?sslmode=require
AGENT_API_BACKUP_S3_ENDPOINT=5c11ff96d03d238d51aef31150a87101.r2.cloudflarestorage.com
AGENT_API_BACKUP_S3_BUCKET=agentapi-backups
AGENT_API_BACKUP_S3_PREFIX=prod/postgres
AGENT_API_BACKUP_S3_ACCESS_KEY=REPLACE_WITH_BACKUP_R2_ACCESS_KEY_ID
AGENT_API_BACKUP_S3_SECRET_KEY=REPLACE_WITH_BACKUP_R2_SECRET_ACCESS_KEY
AGENT_API_BACKUP_RETENTION_DAYS=30

# Container orchestrators should send SIGTERM and allow a grace period longer
# than AGENT_API_SHUTDOWN_TIMEOUT, for example 35s or more.
